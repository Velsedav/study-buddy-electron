{
  "name": "study-buddy-electron",
  "version": "1.8.8",
  "private": true,
  "author": {
    "name": "Velsedav",
    "email": "velasquez.sebastien@gmail.com"
  },
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev --config electron-vite.config.mjs",
    "build": "electron-vite build --config electron-vite.config.mjs",
    "preview": "electron-vite preview --config electron-vite.config.mjs",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "dist": "npm run build && electron-builder",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "build": {
    "appId": "com.velsedav.study-buddy",
    "productName": "Study Buddy",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*"
    ],
    "extraResources": [
      { "from": "src/public", "to": "public" }
    ],
    "linux": {
      "target": ["deb", "AppImage"],
      "icon": "src/public/icon.png",
      "category": "Education"
    },
    "win": {
      "target": "nsis",
      "icon": "src/public/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "src/public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "date-fns": "^4.1.0",
    "electron-auto-launch": "^5.0.5",
    "lucide-react": "^0.575.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "jsdom": "^29.0.0",
    "typescript": "~5.9.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
